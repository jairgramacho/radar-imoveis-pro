# ===== ENVIRONMENT =====
FLASK_ENV=development
FLASK_DEBUG=0

# ===== SECURITY =====
SECRET_KEY=change-me-with-a-secure-random-string-at-least-32-chars

# ===== DATABASE =====
# Development: SQLite (padrão)
# Production: PostgreSQL obrigatório
DATABASE_URL=sqlite:///imoveis.db
# Para PostgreSQL use: postgresql://usuario:senha@localhost:5432/radar_imoveis

# ===== EMAIL (RESEND API - RECOMENDADO NO RENDER) =====
RESEND_API_KEY=your-resend-api-key
RESEND_API_URL=https://api.resend.com/emails
# Opcional: sobrescreve remetente específico do Resend (se vazio, usa MAIL_DEFAULT_SENDER)
RESEND_FROM=
RESEND_TIMEOUT=10

# ===== EMAIL (SMTP - OPCIONAL) =====
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-app
MAIL_DEFAULT_SENDER=noreply@radarimovei.com

# ===== UPLOAD =====
UPLOAD_FOLDER=static/uploads

# ===== APLICAÇÃO =====
APP_URL=http://localhost:5000
ALLOWED_HOSTS=localhost,127.0.0.1
# Controle de confirmação de email no login/cadastro.
# vazio = automático (obrigatório quando email estiver configurado)
# 1 = sempre exige confirmação por email
# 0 = nunca exige confirmação (útil temporariamente enquanto domínio de email não está verificado)
REQUIRE_EMAIL_CONFIRMATION=

# ===== DESENVOLVIMENTO =====
# 0 = exige envio real de email na recuperação de senha
# 1 = permite fallback local para redefinir sem SMTP
ALLOW_DEV_PASSWORD_RESET_FALLBACK=0
