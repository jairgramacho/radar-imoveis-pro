# ===== ENVIRONMENT =====
FLASK_ENV=development
FLASK_DEBUG=0

# ===== SECURITY =====
SECRET_KEY=change-me-with-a-secure-random-string-at-least-32-chars

# ===== DATABASE =====
# Development: SQLite (padrão)
# Production: PostgreSQL obrigatório
DATABASE_URL=sqlite:///imoveis.db
# Para PostgreSQL use: postgresql://usuario:senha@localhost:5432/radar_imoveis

# ===== EMAIL (SMTP) =====
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-app
MAIL_DEFAULT_SENDER=noreply@radarimovei.com

# ===== UPLOAD =====
UPLOAD_FOLDER=static/uploads

# ===== APLICAÇÃO =====
APP_URL=http://localhost:5000
ALLOWED_HOSTS=localhost,127.0.0.1

# ===== DESENVOLVIMENTO =====
# 0 = exige envio real de email na recuperação de senha
# 1 = permite fallback local para redefinir sem SMTP
ALLOW_DEV_PASSWORD_RESET_FALLBACK=0
